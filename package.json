{
  "name": "gho-work",
  "version": "0.0.1",
  "private": true,
  "description": "GHO Work - AI-powered office productivity desktop app",
  "license": "MIT",
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "lint:fix": "eslint --fix 'packages/*/src/**/*.ts' 'apps/*/src/**/*.ts'",
    "clean": "turbo clean",
    "desktop:dev": "cd apps/desktop && npm run dev",
    "desktop:build": "cd apps/desktop && npm run build",
    "format": "prettier --write 'packages/*/src/**/*.ts' 'apps/*/src/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts' 'apps/*/src/**/*.ts'",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "type-check": "turbo build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.0.3",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0"
  }
}
