{
  "name": "gho-work-desktop",
  "version": "0.0.7",
  "private": true,
  "description": "GHO Work - AI-powered office productivity desktop app",
  "author": "Andreas de Ruiter",
  "repository": {
    "type": "git",
    "url": "https://github.com/andreas-deruiter/gho-work.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "clean": "rm -rf out dist",
    "lint": "eslint 'src/**/*.ts'",
    "build:win": "electron-vite build && electron-builder --win --config ../../electron-builder.yml",
    "build:mac": "electron-vite build && electron-builder --mac --config ../../electron-builder.yml",
    "build:linux": "electron-vite build && electron-builder --linux --config ../../electron-builder.yml",
    "publish:mac": "electron-vite build && electron-builder --mac --publish always --config ../../electron-builder.yml",
    "publish:win": "electron-vite build && electron-builder --win --publish always --config ../../electron-builder.yml",
    "publish:linux": "electron-vite build && electron-builder --linux --publish always --config ../../electron-builder.yml"
  },
  "dependencies": {
    "@gho-work/base": "*",
    "@gho-work/platform": "*",
    "@gho-work/ui": "*",
    "@gho-work/electron": "*"
  },
  "devDependencies": {
    "electron": "35.7.5",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
